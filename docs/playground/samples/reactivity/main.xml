<templates>
    <t t-name="example.ShoppingCart">
        <div class="cart">
          <h2>Shopping Cart</h2>
          <input placeholder="Search..." t-model="this.query"/>
          <table>
            <thead><tr><th>Product</th><th>Price</th><th>Qty</th></tr></thead>
            <tbody>
              <t t-foreach="this.filteredProducts()" t-as="p" t-key="p.id">
                <tr>
                  <td><t t-out="p.name"/></td>
                  <td>$<t t-out="p.price"/></td>
                  <td><t t-out="p.qty"/></td>
                  <td>
                    <button t-on-click="() => this.decrease(p)">-</button>
                    <button t-on-click="() => this.increase(p)">+</button>
                  </td>
                </tr>
              </t>
            </tbody>
          </table>
          <hr/>
          <div class="total">Total: $<t t-out="this.total()"/></div>
        </div>
    </t>
</templates>