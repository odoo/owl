<templates>
  <t t-name="hibou.Window">
    <div class="window">
      <div class="window-titlebar">
        <span class="window-title" t-out="this.props.title"/>
        <button class="window-close" t-on-click="() => this.props.onClose?.()">✕</button>
      </div>
      <div class="window-body">
        <t t-call-slot="default"/>
      </div>
    </div>
  </t>
</templates>
