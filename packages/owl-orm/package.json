{
  "name": "@odoo/owl-orm",
  "version": "0.1.0",
  "description": "ORM for Odoo Web Library (OWL)",
  "main": "dist/owl-orm.cjs.js",
  "module": "dist/owl-orm.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/owl-orm.es.js",
      "require": "./dist/owl-orm.cjs.js",
      "default": "./dist/owl-orm.es.js"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@odoo/owl": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odoo/owl.git"
  },
  "author": "Odoo",
  "license": "LGPL-3.0-only"
}
