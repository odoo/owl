// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`basics > basic use 1`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler } = bdom;
  let { createComponent } = helpers;
  const comp1 = createComponent(app, \`Child\`, true, false, false, ["p"]);
  
  return function template(ctx, node, key = "") {
    return comp1({p: 1}, key + \`__1\`, node, this, null);
  }
}"
`;

exports[`basics > basic use 2`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler } = bdom;
  let { safeOutput } = helpers;
  
  let block1 = createBlock(\`<span>child<block-child-0/></span>\`);
  
  return function template(ctx, node, key = "") {
    const b2 = safeOutput(ctx['this'].props.p);
    return block1([], [b2]);
  }
}"
`;

exports[`basics > can select a sub widget  1`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler } = bdom;
  let { createComponent } = helpers;
  const comp1 = createComponent(app, \`Child\`, true, false, false, []);
  const comp2 = createComponent(app, \`OtherChild\`, true, false, false, []);
  
  return function template(ctx, node, key = "") {
    let b2, b3;
    if (ctx['this'].state.options.flag) {
      b2 = comp1({}, key + \`__1\`, node, this, null);
    }
    if (!ctx['this'].state.options.flag) {
      b3 = comp2({}, key + \`__2\`, node, this, null);
    }
    return multi([b2, b3]);
  }
}"
`;

exports[`basics > can select a sub widget  2`] = `
"function anonymous(app, bdom, helpers
