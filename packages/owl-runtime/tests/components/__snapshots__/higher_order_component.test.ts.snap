exports[`basics > sub widget is interactive 2`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler } = bdom;
  let { callHandler, safeOutput } = helpers;
  const hdlr_fn1 = (ctx, ev) => callHandler(ctx['this'].inc, ctx, ev);
  
  let block1 = createBlock(\`<span><button block-handler-0="click">click</button>child<block-child-0/></span>\`);
  
  return function template(ctx, node, key = "") {
    let hdlr1 = [hdlr_fn1, ctx];
    const b2 = safeOutput(ctx['this'].state.val);
    return block1([hdlr1], [b2]);
  }
}"
`;

