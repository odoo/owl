exports[`refs > refs and recursive templates 1`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler } = bdom;
  let { createRef, safeOutput, createComponent } = helpers;
  const comp1 = createComponent(app, \`Test\`, true, false, false, ["tree"]);
  
  let block1 = createBlock(\`<p block-ref="0"><block-child-0/><block-child-1/></p>\`);
  
  return function template(ctx, node, key = "") {
    let b2, b3;
    let ref1 = createRef(ctx['this'].root, node);
    b2 = safeOutput(ctx['this'].props.tree.value);
    if (ctx['this'].props.tree.child) {
      b3 = comp1({tree: ctx['this'].props.tree.child}, key + \`__1\`, node, this, null);
    }
    return block1([ref1], [b2, b3]);
  }
}"
`;

exports[`refs > refs and t-key 1`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler } = bdom;
  let { createRef } = helpers;
  const hdlr_fn1 = (ctx)=>ctx['this'].state.renderId++;
  
  let block2 = createBlock(\`<button block-handler-0="click"/>\`);
  let block3 = createBlock(\`<p block-ref="0"/>\`);
  
  return function template(ctx, node, key = "") {
    let hdlr1 = [hdlr_fn1, ctx];
    const b2 = block2([hdlr1]);
    const tKey_1 = ctx['this'].state.renderId;
    let ref1 = createRef(ctx['this'].root, node);
    const b3 = toggler(tKey_1, block3([ref1]));
    return multi([b2, b3]);
  }
}"
`;

exports[`refs > refs are properly bound in slots 1`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler } = bdom;
  let { safeOutput, callHandler, createRef, markRaw, createComponent } = helpers;
  const hdlr_fn1 = (ctx, ev) => callHandler(ctx['this'].doSomething, ctx, ev);
  const comp1 = createComponent(app, \`Dialog\`, true, true, false, []);
  
  let block1 = createBlock(\`<div><span class="counter"><block-child-0/></span><block-child-1/></div>\`);
  let block3 = createBlock(\`<button block-handler-0="click" block-ref="1">do something</button>\`);
  
  function slot1(ctx, node, key = "") {
    let hdlr1 = [hdlr_fn1, ctx];
    let ref1 = createRef(ctx['this'].button, node);
    return block3([hdlr1, ref1]);
  }
  
  return function template(ctx, node, key = "") {
    const b2 = safeOutput(ctx['this'].state.val);
    const b4 = comp1({slots: markRaw({'footer': {__render: slot1.bind(this), __ctx: ctx}})}, key + \`__1\`, node, this, null);
    return block1([], [b2, b4]);
  }
}"
`;

