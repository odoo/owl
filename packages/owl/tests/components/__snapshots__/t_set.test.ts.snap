  function slot1(ctx, node, key = "") {
    ctx = Object.create(ctx);
    ctx[\`v\`] = new LazyValue(value1, ctx, this, node, key);
    return text(\` in slot \`);
  }
  
  function value1(ctx, node, key = "") {
    return comp1({}, key + \`__1\`, node, this, null);
