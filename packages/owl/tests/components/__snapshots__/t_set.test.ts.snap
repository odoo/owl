exports[`t-set > t-set outside modified in t-if 1`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler, comment } = bdom;
  let { safeOutput } = helpers;
  
  let block1 = createBlock(\`<div><p><block-child-0/></p></div>\`);
  
  return function template(ctx, node, key = "") {
    ctx = Object.create(ctx);
    let b2;
    ctx["iter"] = 0;
    ctx["flag"] = ctx['this'].state.flag;
    if (ctx['flag']==='if') {
      ctx["iter"] = 2;
    } else if (ctx['flag']==='elif') {
      ctx["iter"] = 3;
    } else {
      ctx["iter"] = 4;
    }
    b2 = safeOutput(ctx['iter']);
    return block1([], [b2]);
  }
}"
`;

exports[`t-set > t-set with a component in body 1`] = `
"function anonymous(app, bdom, helpers
) {
  let { text, createBlock, list, multi, html, toggler, comment } = bdom;
  let { LazyValue, createComponent, withDefault, safeOutput } = helpers;
  const comp1 = createComponent(app, \`Child\`, true, false, false, []);
  
  let block1 = createBlock(\`<div><div><block-child-0/></div></div>\`);
  
  function value1(ctx, node, key = "") {
    return comp1({}, key + \`__1\`, node, this, null);
  }
  
  return function template(ctx, node, key = "") {
    ctx = Object.create(ctx);
    ctx[\`v\`] = new LazyValue(value1, ctx, this, node, key);
    const b3 = safeOutput(ctx['v']);
    return block1([], [b3]);
  }
}"
`;

