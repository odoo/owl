<templates>
  <t t-name="TimeTracker">
    <div class="time-tracker">
      <h1>Time Tracker</h1>
      <div class="timer-display">
        <t t-out="this.formattedTime()"/>
      </div>
      <button t-on-click="this.toggleTimer">
        <t t-out="this.isRunning() ? 'Pause' : 'Start'"/>
      </button>
    </div>
  </t>
</templates>
